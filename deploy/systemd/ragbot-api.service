[Unit]
Description=Gloriapets RAG API (FastAPI)
After=network.target

[Service]
Type=simple
User=gautham
WorkingDirectory=/home/gautham/ragbot-poc
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/gautham/ragbot-poc/.venv/bin/uvicorn backend.app:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
