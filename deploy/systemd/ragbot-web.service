[Unit]
Description=Gloriapets RAG Web (Next.js)
After=network.target

[Service]
Type=simple
User=gautham
WorkingDirectory=/home/gautham/ragbot-poc/web
Environment=NODE_ENV=production
Environment=NEXT_PUBLIC_API_BASE_URL=https://gloriapets-chatbot.innovin.win
ExecStart=/usr/bin/npm run start -- --port 3000 --hostname 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
